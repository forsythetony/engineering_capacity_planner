# Engineering Capacity Planner — configuration.
#
# Copy this file to `.env` (which is gitignored) and adjust. Every value has a
# sensible default, so an empty `.env` runs the app on synthetic data. Both the
# backend and the Vite frontend read this single root file.
#
# SECURITY: the SQLite database is the shareable unit. Secrets (the Jira API
# token) live ONLY here / in the environment and are never written to the
# database.

# ─── Backend server ────────────────────────────────────────────────────────
# Host/port the API binds to.
ECP_HOST=127.0.0.1
ECP_PORT=3001
# Path to the SQLite database file (the shareable unit).
ECP_DB_PATH=./data/ecp.db
# Access-Control-Allow-Origin for the API. `*` is fine for a local single-user
# tool; set an explicit origin to lock it down.
ECP_CORS_ORIGIN=*

# ─── Data source ───────────────────────────────────────────────────────────
# Where the domain data comes from: "synthetic" (built-in generator) or "jira".
ECP_DATA_SOURCE=synthetic
# On startup, if the database has no epics, import from the source above.
ECP_SEED_IF_EMPTY=true
# Deterministic seed for the synthetic generator.
ECP_SYNTHETIC_SEED=1

# ─── Jira (used when ECP_DATA_SOURCE=jira; importer lands in Phase 7) ───────
# Connection + mapping. The token is a secret — keep it out of the database.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
# "cloud" or "server".
JIRA_FLAVOR=cloud
# Custom field id holding story points, e.g. customfield_10016.
JIRA_STORY_POINTS_FIELD=
# Issue-link type name that represents "blocks".
JIRA_BLOCKS_LINK_TYPE=Blocks

# ─── Frontend (Vite, build/dev time) ───────────────────────────────────────
# Dev server port and the backend it proxies /api to.
VITE_PORT=5173
VITE_API_TARGET=http://127.0.0.1:3001
# Optional absolute API base for the browser fetch. Leave empty to use the dev
# proxy (same-origin). Set e.g. http://localhost:3001 to bypass the proxy.
VITE_API_BASE=
