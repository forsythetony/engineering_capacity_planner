# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# SQLite databases (generated, not source of truth in the repo).
# Note: only match the DB files themselves — a bare `data/` rule would also
# swallow source dirs like packages/frontend/src/data.
*.db
*.db-shm
*.db-wal
/data/
/packages/*/data/

# Test / coverage
coverage/
test-results/
playwright-report/
.playwright/

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Env
.env
.env.local
